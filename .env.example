# Vault
VAULT_SECRET_KEY=change-me-to-a-random-32-char-string
VAULT_DB_URL=sqlite:///./vault.db
VAULT_TOKEN_EXPIRE_MINUTES=15

# Encryption
VAULT_ENCRYPTION_KEY=         # Generated on first run via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Agent
ANTHROPIC_API_KEY=your-anthropic-api-key-here
VAULT_BASE_URL=http://localhost:8000
AGENT_ID=pam-agent-001

# Target Machine (mock EC2)
TARGET_HOST=localhost
TARGET_PORT=2222
TARGET_USER=ubuntu

# Audit
AUDIT_DB_URL=sqlite:///./audit.db
